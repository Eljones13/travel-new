{
  "expo": {
    "name": "Travel Ravers",
    "slug": "travel-ravers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "travelravers",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eljones13.travelravers",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.eljones13.travelravers"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@morrowdigital/watermelondb-expo-plugin",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Squad Pulse needs your location to share your position with crew via QR code.",
          "locationAlwaysAndWhenInUsePermission": "Squad Pulse needs your location to share your position with crew via QR code."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Squad Pulse needs your camera to scan crew QR codes.",
          "enableCodeScanner": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "kotlinVersion": "1.9.25",
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so",
                "**/libfbjni.so"
              ]
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "461745a4-3b2e-42ad-a3aa-186dad5252bf"
      }
    }
  }
}
